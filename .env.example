# 复制为 .env 后填写真实密钥。
# server.py 启动时会自动读取 .env。

OPENAI_API_KEY=你的真实模型密钥

# 临时公网分享访问密码。源码默认不内置密码；配置后才启用访问验证。
# 生成 Cloudflare Tunnel 公网链接后，别人打开链接需要先输入这个密码。
ACCESS_PASSWORD=请改成你的访问密码

# 如果你使用兼容 OpenAI Chat Completions 的其他服务，也可以改用：
# LLM_API_KEY=你的密钥
# LLM_API_URL=https://你的服务/v1/chat/completions
# LLM_MODEL=你的模型名
# CLOUD_LLM_TIMEOUT=600

# 图片直传视觉模型。默认复用 LLM_API_KEY / LLM_API_URL / LLM_MODEL。
# 如果你的服务有单独视觉模型，可以覆盖下面三项。
# VISION_LLM_ENABLED=true
# VISION_LLM_API_KEY=你的视觉模型密钥
# VISION_LLM_API_URL=https://你的服务/v1/chat/completions
# VISION_LLM_MODEL=你的视觉模型名
# VISION_MAX_IMAGES=6
# VISION_FIRST=true
# PDF_RENDER_SCALE=3.0

# 阿里云百炼 Qwen 多模态示例：
# VISION_LLM_ENABLED=true
# VISION_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# VISION_LLM_MODEL=qwen3.7-plus
# VISION_LLM_API_KEY=你的百炼APIKey
# VISION_MAX_IMAGES=4
# VISION_MAX_IMAGES_REFERENCE=8
# VISION_MAX_IMAGES_SUBMISSION=4
# PDF_RENDER_SCALE=3.0

# 本地模型兜底，默认使用 Ollama 视觉模型。
# 需要先安装 Ollama 并执行：ollama pull qwen2.5vl:7b
# LOCAL_LLM_ENABLED=true
# LOCAL_LLM_PROVIDER=ollama
# LOCAL_LLM_API_URL=http://127.0.0.1:11434/api/chat
# LOCAL_LLM_MODEL=qwen2.5vl:7b
# LOCAL_VISION_ENABLED=true
# LOCAL_VISION_MODEL=qwen2.5vl:7b
# LOCAL_LLM_TIMEOUT=180
